# Copy to .env and fill in. EXPO_PUBLIC_* vars are inlined into the app bundle.
# The publishable/anon key is safe to ship — Row-Level Security is the data boundary.

# Local Supabase (from `supabase start`). For iOS simulator/web, 127.0.0.1 works.
# Android emulator: use http://10.0.2.2:54321 . Physical device: use your machine's LAN IP.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Dev-only: run against an in-memory fake backend instead of Supabase
# (prefer `npm run ios:mock` / `npm run android:mock` over setting this here).
# EXPO_PUBLIC_USE_MOCK=1
